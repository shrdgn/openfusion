# Benchmark recipe for the harder, reasoning-heavy eval (e.g. GSM8K).
# Unlike openfusion.dev.yaml.example, token ceilings are large enough for
# multi-step chain-of-thought so neither solo nor fused answers get truncated.

strategy: self_fusion

self_fusion:
  n: 3
  temperature_spread: [0.2, 0.6, 1.0]
  seed_offset: true

cost_controls:
  pass_through_max_tokens: 512
  panel_max_tokens: 512
  judge_max_tokens: 512

panel:
  - base_url: https://openrouter.ai/api/v1
    api_key: ${OPENROUTER_API_KEY}
    model: openai/gpt-4o-mini
    label: bench-panel

judge:
  base_url: https://openrouter.ai/api/v1
  api_key: ${OPENROUTER_API_KEY}
  model: openai/gpt-4o-mini
  max_panel_tokens: 8000

pass_through:
  base_url: https://openrouter.ai/api/v1
  api_key: ${OPENROUTER_API_KEY}
  model: openai/gpt-4o-mini

timeouts:
  member_seconds: 90
  judge_seconds: 120
  total_seconds: 240

gateway:
  api_keys: []
